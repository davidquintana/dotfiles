# Typography
font-size = 13
font-family = JetBrainsMonoNL Nerd Font Mono, Symbols Nerd Font Mono
#font-thicken = true
font-feature = -liga, -calt
#adjust-cell-height = 2

# Theme/Colors
# theme = Dracula
theme = One Half Dark
# theme = Ayu Mirage
# theme = Builtin Pastel Dark

# Window/Appearance
# background = #000000
background-opacity = 0.97
background-blur-radius = 15
unfocused-split-opacity = 0.60
window-padding-x = 10
window-padding-y = 10
window-decoration = true
window-save-state = always
window-theme = auto

# Mouse
mouse-hide-while-typing = true
selection-invert-fg-bg = true

# Security
clipboard-paste-protection = false

# Cursor
cursor-style = block
cursor-style-blink = true
cursor-opacity = 0.8

# Shell Integration
shell-integration-features = no-cursor, ssh-env, title
# shell-integration-features = cursor, sudo, title

# General 
quit-after-last-window-closed = true
bell-features = attention,title,system
#term = xterm-256color

# keybindings
# keybind for multi-lines in claude code
keybind = shift+enter=text:\n


